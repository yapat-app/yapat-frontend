## Frontend env (Vite)
#
# Copy to `.env` for local dev or configure in your deployment environment.

# Lock the entire UI to a single study phase for a participant session.
# When enabled, URL params and localStorage are ignored and the phase selector
# dropdown is hidden unless you provide an allowlist.
VITE_STUDY_PHASE=P1
VITE_STUDY_PHASE_LOCK=1


# Optional allowlist: when set and lock=1, users can only switch among these
# phases (dropdown shows only these).
# Example:
# VITE_STUDY_PHASE_ALLOWED=P3,P4,P5


# ── Guided study flow (instructions → tour → timed annotation → auto-advance) ──
# Orchestrates each participant through the allowlist phases in order, showing a
# per-phase instructions modal, an incremental guided tour, then a countdown
# timer; when the timer expires the next phase starts automatically.
# Defaults to ON whenever VITE_STUDY_PHASE_LOCK is enabled; set 0 to disable.
VITE_STUDY_FLOW_ENABLED=1

# Minutes allotted to each phase before auto-advancing. Use 5 for pilots, 30 for
# full sessions. Default 5.
VITE_STUDY_PHASE_DURATION_MINUTES=5


# ── Study interaction logging ────────────────────────────────────────────────
# Capture a per-participant, timestamped interaction event stream during the
# Active Learning flow and batch-POST it to /api/study-events/batch.
# Off by default; set to 1/true/yes to enable. See docs/study-logging.md.
VITE_STUDY_LOGGING_ENABLED=0

# How often (seconds) buffered events are flushed to the backend. Default 10.
# VITE_STUDY_LOGGING_FLUSH_SECONDS=10

