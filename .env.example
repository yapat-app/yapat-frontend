## Frontend env (Vite)
#
# Copy to `.env` for local dev or configure in your deployment environment.

# URL of the YAPAT backend API. Required.
VITE_YAPAT_BACKEND_URL=http://localhost:8000

# Public URL of this frontend (used for CORS/links). Optional.
# VITE_YAPAT_FRONTEND_URL=http://localhost:3000
